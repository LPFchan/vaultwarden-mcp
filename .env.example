# Required — Vaultwarden API credentials (from Account Settings → API Key)
VAULTWARDEN_CLIENT_ID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAULTWARDEN_CLIENT_SECRET=your-api-key-here

# Required — MCP server auth token (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
VAULTWARDEN_MCP_AUTH_TOKEN=your-64-char-hex-token

# Required — Vaultwarden admin token for admin panel
VW_ADMIN_TOKEN=your-admin-token-here
